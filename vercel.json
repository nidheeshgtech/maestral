{
  "framework": null,
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    {
      "source": "/((?!.*\\.(php|css|js|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|eot|map|txt|html|xml)).*)",
      "destination": "/index.php"
    }
  ],
  "headers": [
    {
      "source": "/wp-config.php",
      "headers": [{ "key": "x-robots-tag", "value": "noindex" }]
    }
  ]
}
